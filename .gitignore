# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
!.idea/codeStyles/
!.idea/runConfigurations/

# Keystore files
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild/
.cxx/

# Google Services (if not used)
# google-services.json

# Secrets
*.env
credentials.*

# Local database
local_db

# OS files
.DS_Store
Thumbs.db

# Kotlin
.kotlin/

# OMC (oh-my-claudecode tooling)
.omc/

# Backup files
*~
*.swp
*.bak
