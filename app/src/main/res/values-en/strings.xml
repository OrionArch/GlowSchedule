    <string name="import_json_placeholder">[\n  {\n    \"name\": \"Calculus\",\n    ...\n  }\n]</string>
    <string name="import_ai_prompt_text">You are a professional schedule data extraction AI. Please carefully analyze the schedule screenshot I uploaded, extract the course names, teachers, classrooms, day of the week (1-7, 1=Monday, 7=Sunday), start/end periods (1-12), and active weeks into a standard JSON array format and output it directly (no extra explanations, just JSON). Format example:\n[\n  {\n    \"name\": \"Calculus\",\n    \"teacher\": \"Prof. Li\",\n    \"classroom\": \"Room 302\",\n    \"day\": 1,\n    \"start\": 3,\n    \"end\": 4,\n    \"weeks\": \"1,2,3,4,5,6,7,8\"\n  }\n]</string>
